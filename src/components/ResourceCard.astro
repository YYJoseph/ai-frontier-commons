---
import TopicBadge from "./TopicBadge.astro";
import type { Resource } from "../lib/schema";

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;
const typeLabels: Record<string, string> = {
  paper: "论文",
  repo: "开源项目",
  article: "文章",
  interview: "访谈",
  podcast: "访谈节目",
  course: "课程",
  "teaching-video": "教学视频",
  documentation: "官方文档",
  framework: "框架",
  "skill-plugin": "Skills / 插件",
  tool: "工具",
  dataset: "数据集",
  talk: "演讲"
};
const difficultyLabels: Record<string, string> = {
  beginner: "入门",
  intermediate: "进阶",
  advanced: "高级"
};
---

<article class="group flex h-full flex-col rounded-lg border border-stone-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-teal-200 hover:shadow-lg hover:shadow-stone-200/70">
  <div class="mb-4 flex flex-wrap items-center gap-2 text-xs font-semibold text-slate-500">
    <span class="rounded bg-ink px-2 py-1 text-white">{typeLabels[resource.type] ?? resource.type}</span>
    <span>·</span>
    <span>{difficultyLabels[resource.difficulty] ?? resource.difficulty}</span>
    <span>·</span>
    <span>{resource.source}</span>
  </div>
  <h2 class="text-lg font-semibold leading-7 text-ink">
    <a class="group-hover:text-accent" href={resource.url} target="_blank" rel="noreferrer">{resource.title}</a>
  </h2>
  {resource.people && (
    <p class="mt-2 text-sm text-slate-500">相关人物：{resource.people.join(", ")}</p>
  )}
  <p class="mt-3 text-sm leading-6 text-slate-700">{resource.summary}</p>
  <p class="mt-3 border-l-2 border-saffron/60 pl-3 text-sm leading-6 text-slate-600"><strong>为什么值得看：</strong>{resource.whyItMatters}</p>
  <div class="mt-auto flex flex-wrap gap-2 pt-5">
    {resource.topics.map((topic: string) => <TopicBadge label={topic} />)}
  </div>
</article>
