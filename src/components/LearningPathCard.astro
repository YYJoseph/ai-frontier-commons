---
import type { LearningPath, Resource, TopicNode } from "../lib/schema";

interface Props {
  path: LearningPath;
  topics: TopicNode[];
  resources: Resource[];
}

const { path, topics, resources } = Astro.props;
const topicById = new Map<string, TopicNode>(topics.map((topic: TopicNode) => [topic.id, topic]));
const resourceById = new Map<string, Resource>(resources.map((resource: Resource) => [resource.id, resource]));
---

<article class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-orange-200 hover:shadow-lg hover:shadow-stone-200/70">
  <p class="text-sm font-semibold leading-6 text-coral">{path.audience}</p>
  <h2 class="mt-2 text-xl font-semibold text-ink">{path.title}</h2>
  <p class="mt-3 text-sm leading-6 text-slate-700">{path.summary}</p>
  <div class="mt-5">
    <h3 class="text-sm font-semibold text-ink">覆盖主题</h3>
    <div class="mt-2 flex flex-wrap gap-2">
      {path.topicIds.map((id: string) => <span class="rounded-full border border-teal-100 bg-teal-50 px-3 py-1 text-xs text-accent">{topicById.get(id)?.title ?? id}</span>)}
    </div>
  </div>
  <div class="mt-5">
    <h3 class="text-sm font-semibold text-ink">起步资源</h3>
    <ul class="mt-2 space-y-2 text-sm text-slate-700">
      {path.resourceIds.map((id: string) => {
        const resource = resourceById.get(id);
        return <li><a class="hover:text-accent" href={resource?.url} target="_blank" rel="noreferrer">{resource?.title ?? id}</a></li>;
      })}
    </ul>
  </div>
</article>
