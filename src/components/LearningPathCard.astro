---
import type { LearningPath, Resource, TopicNode } from "../lib/schema";

interface Props {
  path: LearningPath;
  topics: TopicNode[];
  resources: Resource[];
}

const { path, topics, resources } = Astro.props;
const topicById = new Map<string, TopicNode>(topics.map((topic: TopicNode) => [topic.id, topic]));
const resourceById = new Map<string, Resource>(resources.map((resource: Resource) => [resource.id, resource]));
---

<article class="rounded-lg border border-clay/60 bg-porcelain/75 p-6 shadow-sm transition hover:border-accent/30 hover:shadow-md hover:shadow-clay/30 md:p-8">
  <p class="text-sm font-semibold leading-6 text-coral">{path.audience}</p>
  <h2 class="mt-2 text-2xl font-semibold text-ink">{path.title}</h2>
  <p class="mt-3 text-base leading-7 text-slate-700">{path.summary}</p>

  {path.stages && (
    <div class="mt-7">
      <h3 class="text-sm font-semibold text-ink">学习阶段与内在连接</h3>
      {path.stages.map((stage, index: number) => (
        <section class="relative border-l border-clay/70 py-5 pl-6">
          <span class="absolute -left-3 top-5 flex h-6 w-6 items-center justify-center rounded-full bg-ink text-xs font-semibold text-white">{index + 1}</span>
          <h4 class="text-lg font-semibold text-ink">{stage.title}</h4>
          <div class="mt-3 space-y-4">
            <div class="space-y-3">
              <p class="text-sm leading-6 text-slate-700">{stage.focus}</p>
              <p class="border-l-2 border-saffron/50 pl-3 text-sm leading-6 text-slate-600">{stage.connection}</p>
              {stage.checkpoint && (
                <p class="rounded-md bg-linen px-3 py-2 text-sm leading-6 text-accent"><strong>学完应能：</strong>{stage.checkpoint}</p>
              )}
            </div>
            <div>
              <p class="text-xs font-semibold text-slate-500">推荐资源</p>
              <ul class="mt-2 space-y-1.5 text-sm text-slate-700">
                {stage.resourceIds.map((id: string) => {
                  const resource = resourceById.get(id);
                  return <li><a class="hover:text-accent" href={resource?.url} target="_blank" rel="noreferrer">{resource?.title ?? id}</a></li>;
                })}
              </ul>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            {stage.topicIds.map((id: string) => <span class="rounded-full border border-clay/60 bg-porcelain px-2.5 py-1 text-xs text-accent">{topicById.get(id)?.title ?? id}</span>)}
          </div>
        </section>
      ))}
    </div>
  )}

  <div class="mt-6 border-t border-clay/60 pt-5">
    <h3 class="text-sm font-semibold text-ink">覆盖主题</h3>
    <div class="mt-2 flex flex-wrap gap-2">
      {path.topicIds.map((id: string) => <span class="rounded-full border border-clay/60 bg-linen px-3 py-1 text-xs text-accent">{topicById.get(id)?.title ?? id}</span>)}
    </div>
  </div>
  <div class="mt-5">
    <h3 class="text-sm font-semibold text-ink">起步资源</h3>
    <ul class="mt-2 space-y-2 text-sm text-slate-700">
      {path.resourceIds.map((id: string) => {
        const resource = resourceById.get(id);
        return <li><a class="hover:text-accent" href={resource?.url} target="_blank" rel="noreferrer">{resource?.title ?? id}</a></li>;
      })}
    </ul>
  </div>
</article>
