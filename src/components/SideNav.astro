---
interface NavItem {
  href: string;
  label: string;
  meta?: string;
}

interface Props {
  title: string;
  items: NavItem[];
}

const { title, items } = Astro.props;
---

<aside class="lg:sticky lg:top-24 lg:self-start">
  <nav class="rounded-lg border border-clay/70 bg-porcelain/80 p-4 shadow-sm backdrop-blur">
    <p class="px-2 text-xs font-semibold uppercase tracking-wide text-moss">{title}</p>
    <div class="mt-3 space-y-1">
      {items.map((item) => (
        <a class="block rounded-md px-2 py-2 text-sm leading-5 text-slate-700 hover:bg-linen hover:text-ink" href={item.href}>
          <span class="block font-medium">{item.label}</span>
          {item.meta && <span class="mt-0.5 block text-xs text-slate-500">{item.meta}</span>}
        </a>
      ))}
    </div>
  </nav>
</aside>
