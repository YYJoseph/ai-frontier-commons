---
import type { TopicNode } from "../lib/schema";

interface Props {
  topics: TopicNode[];
}

interface RenderedTopicNode {
  topic: TopicNode;
  children: RenderedTopicNode[];
}

const { topics } = Astro.props;
const topicById = new Map<string, TopicNode>(topics.map((topic: TopicNode) => [topic.id, topic]));
const roots = topics.filter((topic: TopicNode) => !topic.parentId);

const renderNode = (topic: TopicNode): RenderedTopicNode => {
  const children = (topic.children || [])
    .map((childId: string) => topicById.get(childId))
    .filter((child): child is TopicNode => Boolean(child));
  return { topic, children: children.map(renderNode) };
};

const tree = roots.map(renderNode);
---

<div class="space-y-4">
  {tree.map(({ topic, children }) => (
    <section class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
      <h2 class="text-2xl font-semibold text-ink">{topic.title}</h2>
      <p class="mt-2 text-sm leading-6 text-slate-700">{topic.summary}</p>
      {children.length > 0 && (
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          {children.map(({ topic: child, children: grandChildren }) => (
            <div class="rounded-md border border-stone-200 bg-paper p-4">
              <h3 class="font-semibold text-ink">{child.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{child.summary}</p>
              {grandChildren.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {grandChildren.map(({ topic: grandChild }) => (
                    <span class="rounded-full border border-stone-200 bg-white px-3 py-1 text-xs text-slate-600">{grandChild.title}</span>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </section>
  ))}
</div>
