---
import "../styles/global.css";
import { withBase } from "../lib/paths";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "让每个对 AI 感兴趣的人，都能看见知识的全貌，并参与建设它。"
} = Astro.props;

const navItems = [
  { href: withBase("/"), label: "首页" },
  { href: withBase("/resources"), label: "资源库" },
  { href: withBase("/knowledge-tree"), label: "知识树" },
  { href: withBase("/learning-paths"), label: "学习路径" },
  { href: withBase("/contribute"), label: "参与共建" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AI Frontier Commons</title>
  </head>
  <body>
    <header class="sticky top-0 z-20 border-b border-clay/50 bg-porcelain/85 backdrop-blur-xl">
      <nav class="mx-auto flex max-w-7xl flex-wrap items-center justify-between gap-4 px-5 py-4">
        <a href={withBase("/")} class="group flex items-center gap-3 text-ink">
          <span class="grid h-9 w-9 place-items-center rounded-md bg-ink text-sm font-semibold text-porcelain shadow-sm">AI</span>
          <span>
            <span class="block text-base font-semibold leading-tight">AI Frontier Commons</span>
            <span class="block text-xs text-slate-500">开放的 AI 学习共建计划</span>
          </span>
        </a>
        <div class="flex flex-wrap gap-1 rounded-md border border-clay/60 bg-porcelain/70 p-1 text-sm text-slate-600 shadow-sm">
          {navItems.map((item) => <a class="rounded px-3 py-2 hover:bg-linen hover:text-ink" href={item.href}>{item.label}</a>)}
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="border-t border-clay/60 bg-porcelain/80">
      <div class="mx-auto flex max-w-7xl flex-col gap-3 px-5 py-8 text-sm text-slate-600 md:flex-row md:items-center md:justify-between">
        <p>让每个对 AI 感兴趣的人，都能看见知识的全貌，并参与建设它。</p>
        <a class="font-semibold text-accent" href={withBase("/contribute")}>参与共建</a>
      </div>
    </footer>
  </body>
</html>
