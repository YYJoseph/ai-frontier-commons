---
import BaseLayout from "../layouts/BaseLayout.astro";
import KnowledgeTree from "../components/KnowledgeTree.astro";
import SideNav from "../components/SideNav.astro";
import topics from "../data/topics.json";
import worldModelTopics from "../data/world-model-topics.json";
import type { TopicNode } from "../lib/schema";

const allTopics = topics as TopicNode[];
const allWorldModelTopics = worldModelTopics as TopicNode[];
const navItems = [
  { href: "#ai-engineering-tree", label: "AI 工程知识树", meta: `${allTopics.length} 个节点` },
  { href: "#world-model-tree", label: "世界模型知识树", meta: `${allWorldModelTopics.length} 个节点` }
];
---

<BaseLayout title="知识树">
  <section class="mx-auto max-w-7xl px-5 py-12">
    <div class="rounded-lg border border-clay/70 bg-porcelain/80 p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent">知识树</p>
      <h1 class="mt-3 text-4xl font-semibold text-ink">持续生长的 AI 知识地图</h1>
      <p class="mt-4 max-w-3xl text-slate-700">
        知识树会把前沿概念放回体系中。当前包含 AI 工程知识树和世界模型知识树，两条主线分开展示，方便你从不同方向建立全局结构。
      </p>
    </div>
    <div class="mt-10 grid gap-8 lg:grid-cols-[15rem_1fr]">
      <SideNav title="树状目录" items={navItems} />
      <div>
        <section id="ai-engineering-tree" class="scroll-mt-28">
          <div class="mb-6">
            <p class="text-sm font-semibold uppercase tracking-wide text-accent">AI Engineering</p>
            <h2 class="mt-2 text-3xl font-semibold text-ink">AI 工程知识树</h2>
          </div>
          <KnowledgeTree topics={allTopics} />
        </section>

        <section id="world-model-tree" class="mt-14 scroll-mt-28">
          <div class="mb-6 rounded-lg border border-clay/70 bg-porcelain/80 p-8 shadow-sm">
            <p class="text-sm font-semibold uppercase tracking-wide text-accent">World Models</p>
            <h2 class="mt-3 text-3xl font-semibold text-ink">世界模型知识树</h2>
            <p class="mt-4 max-w-3xl text-slate-700">
              世界模型关注的是 AI 如何在内部建立对环境的预测模型，并把这种预测用于规划、控制、具身交互和生成式仿真。它和 LLM/Agent 工程有关，但主线更偏向“理解世界如何变化”。
            </p>
          </div>
          <KnowledgeTree topics={allWorldModelTopics} />
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
