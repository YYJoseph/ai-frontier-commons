---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResourceCard from "../components/ResourceCard.astro";
import resources from "../data/resources.json";
import topics from "../data/topics.json";
import paths from "../data/learning-paths.json";
import type { LearningPath, Resource, TopicNode } from "../lib/schema";
import { withBase } from "../lib/paths";

const allResources = resources as Resource[];
const allTopics = topics as TopicNode[];
const allPaths = paths as LearningPath[];
const featured = allResources.slice(0, 4);
---

<BaseLayout title="首页">
  <section class="border-b border-stone-200/80 bg-porcelain">
    <div class="mx-auto grid max-w-7xl gap-10 px-5 py-14 lg:grid-cols-[1.08fr_0.92fr] lg:items-center lg:py-20">
      <div>
        <p class="inline-flex rounded-full border border-teal-200 bg-teal-50 px-3 py-1 text-sm font-semibold text-accent">开放的 AI 学习共建计划</p>
        <h1 class="mt-6 max-w-4xl text-4xl font-bold leading-tight text-ink md:text-6xl">
          让每个对 AI 感兴趣的人，都能看见知识的全貌，并参与建设它。
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-700">
          AI Frontier Commons 收录前沿论文、开源项目、研究者访谈、课程、工具与学习路径，并把它们整理成一个社区共建的 AI 知识空间。
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="rounded-md bg-ink px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-accent" href={withBase("/resources")}>浏览资源</a>
          <a class="rounded-md border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-ink shadow-sm hover:border-accent hover:text-accent" href={withBase("/knowledge-tree")}>查看知识树</a>
          <a class="rounded-md px-5 py-3 text-sm font-semibold text-accent hover:bg-teal-50" href={withBase("/contribute")}>参与共建</a>
        </div>
      </div>
      <aside class="rounded-lg border border-stone-200 bg-white p-5 shadow-xl shadow-stone-200/60">
        <div class="flex items-center justify-between border-b border-stone-100 pb-4">
          <div>
            <p class="text-sm font-semibold text-saffron">学习雷达</p>
            <h2 class="mt-1 text-2xl font-bold text-ink">本周从这里开始</h2>
          </div>
          <span class="rounded bg-teal-50 px-3 py-1 text-xs font-semibold text-accent">MVP</span>
        </div>
        <div class="mt-5 space-y-4">
          {featured.slice(0, 3).map((resource, index) => (
            <a class="block rounded-md border border-stone-100 bg-paper/70 p-4 hover:border-teal-200 hover:bg-teal-50/60" href={resource.url} target="_blank" rel="noreferrer">
              <p class="text-xs font-semibold text-slate-500">0{index + 1} · {resource.source}</p>
              <h3 class="mt-2 font-semibold leading-6 text-ink">{resource.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{resource.summary}</p>
            </a>
          ))}
        </div>
      </aside>
    </div>
  </section>
  <section class="mx-auto grid max-w-7xl gap-4 px-5 py-8 md:grid-cols-3">
    <div class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
      <p class="text-3xl font-bold text-ink">{allResources.length}</p>
      <p class="mt-1 text-sm text-slate-600">精选资源</p>
    </div>
    <div class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
      <p class="text-3xl font-bold text-ink">{allTopics.length}</p>
      <p class="mt-1 text-sm text-slate-600">知识节点</p>
    </div>
    <div class="rounded-lg border border-stone-200 bg-white p-6 shadow-sm">
      <p class="text-3xl font-bold text-ink">{allPaths.length}</p>
      <p class="mt-1 text-sm text-slate-600">学习路径</p>
    </div>
  </section>
  <section class="mx-auto max-w-7xl px-5 py-12">
    <div class="mb-6 flex items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-coral">精选内容</p>
        <h2 class="mt-2 text-2xl font-bold text-ink">从这些高质量资源开始学习</h2>
      </div>
      <a class="text-sm font-semibold text-accent" href={withBase("/resources")}>查看全部</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      {featured.map((resource) => <ResourceCard resource={resource} />)}
    </div>
  </section>
</BaseLayout>
