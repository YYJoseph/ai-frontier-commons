---
import BaseLayout from "../layouts/BaseLayout.astro";
import ResourceCard from "../components/ResourceCard.astro";
import resources from "../data/resources.json";
import type { Resource } from "../lib/schema";

const interviews = (resources as Resource[]).filter((resource: Resource) => resource.type === "interview" || resource.type === "talk");
---

<BaseLayout title="访谈">
  <section class="mx-auto max-w-7xl px-5 py-12">
    <div class="rounded-lg border border-stone-200 bg-porcelain p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent">人物与访谈</p>
      <h1 class="mt-3 text-4xl font-bold text-ink">向 AI 研究者和实践者学习</h1>
      <p class="mt-4 max-w-2xl text-slate-700">收录访谈、播客、演讲、公开课和 AMA，帮助学习者理解 AI 从业者如何思考问题。</p>
    </div>
    <div class="mt-10 grid gap-5 md:grid-cols-2">
      {interviews.map((resource) => <ResourceCard resource={resource} />)}
    </div>
  </section>
</BaseLayout>
