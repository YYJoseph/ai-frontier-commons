---
import BaseLayout from "../layouts/BaseLayout.astro";
import LearningPathCard from "../components/LearningPathCard.astro";
import SideNav from "../components/SideNav.astro";
import paths from "../data/learning-paths.json";
import topics from "../data/topics.json";
import worldModelTopics from "../data/world-model-topics.json";
import resources from "../data/resources.json";
import type { LearningPath, Resource, TopicNode } from "../lib/schema";

const allPaths = paths as LearningPath[];
const allTopics = [...(topics as TopicNode[]), ...(worldModelTopics as TopicNode[])];
const allResources = resources as Resource[];
const navItems = allPaths.map((path: LearningPath) => ({
  href: `#${path.id}`,
  label: path.title,
  meta: `${path.stages?.length ?? 0} 个阶段`
}));
---

<BaseLayout title="学习路径">
  <section class="mx-auto max-w-7xl px-5 py-12">
    <div class="rounded-lg border border-clay/70 bg-porcelain/80 p-8 shadow-sm">
      <p class="text-sm font-semibold uppercase tracking-wide text-accent">学习路径</p>
      <h1 class="mt-3 text-4xl font-semibold text-ink">不要只刷信息流，沿着路径学习</h1>
      <p class="mt-4 max-w-3xl text-slate-700">精选学习路径会把资源组织成可以真正跟着走的顺序。每条路径都说明阶段目标、知识之间的连接，以及学完后应该能判断什么。</p>
    </div>
    <div class="mt-10 grid gap-8 lg:grid-cols-[15rem_1fr]">
      <SideNav title="路径目录" items={navItems} />
      <div class="space-y-6">
        {allPaths.map((path: LearningPath) => (
          <section id={path.id} class="scroll-mt-28">
            <LearningPathCard path={path} topics={allTopics} resources={allResources} />
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
